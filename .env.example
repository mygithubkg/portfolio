# ============================================
# FIREBASE AUTH — Admin Account
# ============================================
# Your Firebase Auth admin user's UID.
# Get this from: Firebase Console → Authentication → Users → copy the UID column
# Also paste this into firestore.rules in the isAdmin() function.
VITE_ADMIN_UID=your_firebase_auth_uid_here

# Your admin email address (used when creating the Firebase Auth account).
# Not referenced in code — for your own documentation only.
# VITE_ADMIN_EMAIL=admin@yourproject.com

# ============================================
# DEPRECATED — Replaced by Firebase Auth
# These were used for the old pseudo-auth login.
# They are no longer used by the application.
# Remove them once Firebase Auth is configured.
# ============================================
# VITE_ADMIN_USERNAME=admin
# VITE_ADMIN_PASSWORD=YourSecurePasswordHere

# ============================================
# FIREBASE PROJECT CREDENTIALS
# Get these from: Firebase Console → Project Settings → Your apps
# ============================================
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================
# EMAILJS — Contact form
# Get these from: https://www.emailjs.com/
# ============================================
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ============================================
# INSTRUCTIONS
# 1. Copy this file to .env
# 2. Create Firebase Auth admin user — see MIGRATION.md
# 3. Fill in VITE_ADMIN_UID and VITE_FIREBASE_* values
# 4. Update firestore.rules with your admin UID
# 5. Never commit .env to Git
# ============================================
